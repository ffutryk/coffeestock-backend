# Host de la base de datos (Opcional).
# - Para Docker Compose: psql-db
# - Para ejecución local (sin Docker): localhost
# POSTGRES_HOSTNAME=localhost

# Puerto donde escucha la base de datos (Opcional, por defecto 5432).
# POSTGRES_PORT=5432

# Credenciales de acceso a PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=coffeestock

# Puerto para el servidor del backend (ej: 3000)
BACKEND_PORT=3000

# Puerto para el servidor del frontend/Vite (ej: 5173)
FRONTEND_PORT=5173

# Clave secreta para firmar los tokens JWT.
JWT_SECRET=x2ZxRWjGVavFfV2MCGCFWhdXULKyZCN11dST0Ul2Jtw

# Entorno de ejecución: 'dev' para desarrollo, 'prod' para producción.
NODE_ENV=dev